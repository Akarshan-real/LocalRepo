{
    "manifest_version": 3,
    "name": "Interchange",
    "version": "1.0",
    "action": {
        "default_popup": "popup.html"
    },
    "permissions": [
        "tabs"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://*.youtube.com/*",
                "https://*.spotify.com/*"
            ],
            "js": [
                "contentScript.js"
            ]
        }
    ]
}